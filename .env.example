# ─────────────────────────────────────────────
#  FraudGuard — Environment Variables Template
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The application uses python-dotenv to load these automatically.

# ── Required ──────────────────────────────────
# Anthropic Claude API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Database (already used by FastAPI service) ─
DB_HOST=localhost
DB_NAME=fraud_detection
DB_USER=postgres
DB_PASSWORD=password

# ── Redis ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Optional: Email Alerts ─────────────────────
# If set, FraudGuard will email the fraud team on HIGH_RISK / CRITICAL alerts.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=fraud-team@yourbank.com

# ── Optional: Webhook Alerts ───────────────────
# POST a JSON payload to this URL on every alert (Slack, PagerDuty, etc.)
WEBHOOK_URL=
